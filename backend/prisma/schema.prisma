// ============================================
// FreelanceIT — Prisma Schema (PostgreSQL)
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  // Supabase/pgBouncer: disable prepared statement caching to avoid "42P05" errors
  // This is automatically appended to DATABASE_URL if not present
}

// ─── User ─────────────────────────────────────

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  password          String
  role              String   @default("CANDIDAT") // CANDIDAT | RECRUTEUR | ADMIN
  isVerified        Boolean  @default(false)
  verificationToken String?
  googleId          String?  @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  profileCandidat  ProfileCandidat?
  profileRecruteur ProfileRecruteur?
  jobOffers        JobOffer[]
  sentMessages          Message[]        @relation("SentMessages")
  recruiterConversations Conversation[] @relation("RecruiterConversations")
  candidateConversations Conversation[] @relation("CandidateConversations")
  notifications    Notification[]
  savedCandidates  SavedCandidate[]
  applications     Application[]    @relation("CandidateApplications")
  quizAttempts     QuizAttempt[]    @relation("QuizAttempts")
  reviewsGiven     Review[]         @relation("ReviewsGiven")
  reviewsReceived  Review[]         @relation("ReviewsReceived")
  communityPosts   CommunityPost[]
  contractsAsRecruiter Contract[]   @relation("ContractsAsRecruiter")
  contractsAsCandidate Contract[]   @relation("ContractsAsCandidate")

  @@map("users")
}

// ─── Profile Candidat ─────────────────────────

model ProfileCandidat {
  id                String   @id @default(cuid())
  userId            String   @unique
  firstName         String
  lastName          String
  email             String?
  title             String?
  bio               String?
  skills            String   @default("[]") // JSON array stored as string
  yearsOfExperience Int?
  availability      String   @default("DISPONIBLE") // DISPONIBLE | EN_MISSION | BIENTOT_DISPONIBLE
  portfolioUrl      String?
  tjm               Int?
  location          String?
  phone             String?
  linkedIn          String?
  avatarUrl         String?
  status            String   @default("DRAFT") // DRAFT | PUBLISHED
  draftData         String?  // JSON object for saving draft progress
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  experiences   Experience[]
  educations    Education[]

  @@map("profiles_candidat")
}

// ─── Experience ────────────────────────────────

model Experience {
  id              String   @id @default(cuid())
  profileId       String
  title           String
  company         String
  location        String?
  description     String?
  startDate       DateTime?
  endDate         DateTime?
  currentlyWorking Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profile ProfileCandidat @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("experiences")
}

// ─── Education ─────────────────────────────────

model Education {
  id          String   @id @default(cuid())
  profileId   String
  title       String   // Diploma/Degree title
  school      String   // School/University name
  field       String?  // Field of study
  description String?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile ProfileCandidat @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("educations")
}

// ─── Profile Recruteur ────────────────────────

model ProfileRecruteur {
  id        String   @id @default(cuid())
  userId    String   @unique
  firstName String
  lastName  String
  company   String
  position  String?
  phone     String?
  website   String?
  avatarUrl String?
  description String?
  sector      String?
  verificationStatus String  @default("NONE") // NONE | PENDING | VERIFIED | REJECTED
  verificationDocUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles_recruteur")
}

// ─── Job Offer ────────────────────────────────

model JobOffer {
  id           String   @id @default(cuid())
  recruiterId  String
  title        String
  company      String
  description  String
  location     String
  remote       Boolean  @default(false)
  contractType String   @default("FREELANCE") // FREELANCE | CDI | CDD
  tjm          Int?
  salaryMin    Int?
  salaryMax    Int?
  tags            String   @default("[]") // JSON array stored as string
  requiredQuizzes String   @default("[]") // JSON: [{skill, minScore}]
  status          String   @default("ACTIVE") // ACTIVE | CLOSED | DRAFT
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  expiresAt    DateTime?

  recruiter User @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  applications Application[]

  @@map("job_offers")
}

// ─── Application ──────────────────────────────

model Application {
  id          String   @id @default(cuid())
  jobId       String
  candidateId String
  coverLetter String?
  cvUrl       String?
  status      String   @default("PENDING") // PENDING | REVIEW | ACCEPTED | REJECTED | WITHDRAWN
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  job       JobOffer @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate User     @relation("CandidateApplications", fields: [candidateId], references: [id], onDelete: Cascade)
  reviews   Review[]
  contract  Contract?

  @@unique([jobId, candidateId])
  @@index([candidateId])
  @@index([jobId])
  @@map("applications")
}

// ─── Messaging ────────────────────────────────

model Conversation {
  id            String   @id @default(cuid())
  recruiterId   String
  candidateId   String
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  recruiter User      @relation("RecruiterConversations", fields: [recruiterId], references: [id], onDelete: Cascade)
  candidate User      @relation("CandidateConversations", fields: [candidateId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([recruiterId, candidateId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ─── Notification ─────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // PROFILE_SAVED | MESSAGE_RECEIVED | JOB_MATCH
  title     String
  message   String
  read      Boolean  @default(false)
  metadata  String?  // JSON string
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── Quiz & QCM ───────────────────────────────

model Quiz {
  id          String   @id @default(cuid())
  skill       String   @unique // "Python", "React", "SQL", etc.
  title       String
  description String?
  difficulty  String   @default("INTERMEDIATE") // BEGINNER | INTERMEDIATE | ADVANCED
  questions   String   // JSON array — correctIndex excluded from API responses
  timeLimit   Int      @default(15) // minutes
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attempts QuizAttempt[]

  @@map("quizzes")
}

model QuizAttempt {
  id          String   @id @default(cuid())
  quizId      String
  candidateId String
  score       Int      // 0-100
  totalQ      Int      // number of questions
  correctQ    Int      // number correct
  answers     String   // JSON: { [questionId]: selectedIndex }
  completedAt DateTime @default(now())

  quiz      Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  candidate User @relation("QuizAttempts", fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([quizId])
  @@map("quiz_attempts")
}

// ─── Saved Candidate ──────────────────────────

model SavedCandidate {
  id          String   @id @default(cuid())
  recruiterId String
  candidateId String
  createdAt   DateTime @default(now())

  recruiter User @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  @@unique([recruiterId, candidateId])
  @@map("saved_candidates")
}

// ─── Community Post ───────────────────────────

model CommunityPost {
  id          String   @id @default(cuid())
  authorId    String
  title       String
  content     String
  type        String   @default("ARTICLE") // ARTICLE | DOCUMENT | QUESTION
  category    String   @default("GENERAL") // GENERAL | RETOUR_XP | CONSEIL | OUTIL | JURIDIQUE
  fileUrl     String?
  tags        String   @default("[]") // JSON array
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  rejectReason String?
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([authorId])
  @@map("community_posts")
}

// ─── Content Block (admin) ────────────────────

model ContentBlock {
  id        String   @id @default(cuid())
  page      String   // HOME | OFFRES | COMMUNAUTE | GLOBAL
  title     String?
  content   String   // Markdown / HTML
  type      String   @default("BANNER") // BANNER | ALERT | INFO | PROMO
  isVisible Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([page, isVisible])
  @@map("content_blocks")
}

// ─── Review / Réputation ──────────────────────

model Review {
  id            String   @id @default(cuid())
  fromUserId    String
  toUserId      String
  applicationId String?
  rating        Int      // 1-5
  comment       String?
  type          String   // RECRUTEUR_TO_CANDIDAT | CANDIDAT_TO_RECRUTEUR
  badges        String   @default("[]") // JSON: ["MISSION_REUSSIE","LIVRAISON_RAPIDE","LONG_TERME","EXPERT_TECHNIQUE","BON_COMMUNICANT"]
  createdAt     DateTime @default(now())

  from        User         @relation("ReviewsGiven", fields: [fromUserId], references: [id], onDelete: Cascade)
  to          User         @relation("ReviewsReceived", fields: [toUserId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@unique([fromUserId, applicationId])
  @@index([toUserId])
  @@map("reviews")
}

// ─── Contracts ────────────────────────────────

model Contract {
  id                String    @id @default(cuid())
  applicationId     String    @unique
  recruiterId       String
  candidateId       String
  title             String
  tjm               Int?
  startDate         DateTime?
  duration          String?
  clauses           String?   @db.Text
  status            String    @default("PENDING") // PENDING | SIGNED | REFUSED | CANCELLED
  recruiterSignedAt DateTime  @default(now())
  candidateSignedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  recruiter   User        @relation("ContractsAsRecruiter", fields: [recruiterId], references: [id])
  candidate   User        @relation("ContractsAsCandidate", fields: [candidateId], references: [id])

  @@index([recruiterId])
  @@index([candidateId])
  @@map("contracts")
}
